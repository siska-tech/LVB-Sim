% ─────────────────────────────────────────────────────────────────────
% iron_citadel.mmml  —  Iron Citadel
%                        Mega Man 2 Wily Stage インスパイア
%
% t39 ≈ 161 BPM  |  4/4  |  48 bars  |  約72秒
%
%   CH1 : リードメロディ (A マイナー 主題)
%   CH2 : ベースライン  (A マイナー ルートモーション)
%   CH3 : t255 (効果音用に確保)
%   CH4 : ドラム        (NES 風 16分音符ハイハット)
%
% mmml オクターブ対応:
%   o1 → 第4オクターブ (A4≈440Hz, E4≈330Hz, C4≈262Hz)
%   o2 → 第5オクターブ (A5≈880Hz, E5≈659Hz, C5≈523Hz)
%
% CH4 サンプルマップ:
%   d  → kick  (sample 3)
%   d+ → snare (sample 4)
%   e  → hi-hat (sample 5)
%
% 構成:
%   Part A × 2  : 8bars × 2 = 16bars  (Aマイナー 主題 / 上昇アルペジオ)
%   Part B × 2  : 8bars × 2 = 16bars  (半音階ラン / ドラマティック展開)
%   Reprise × 2 : 8bars × 2 = 16bars  (A主題リプライズ)
%   合計 48bars
% ─────────────────────────────────────────────────────────────────────


@ t39

% ══════════════════════════════════════════════════════════════════════
% CH1: LEAD — A マイナー 主題
% ══════════════════════════════════════════════════════════════════════

% ── Part A × 2  (8bars × 2 = 16bars) ─────────────────────────────────
[2
% bar 1: A4(q) C5(e) E5(e) A5(q) G5(e) F5(e) — Am アルペジオ上昇
o1a4 o2c8 e8 a4 g8 f8
% bar 2: E5(q.) D5(e) C5(q) B4(q)
o2e4. d8 c4 o1b4
% bar 3: C5(q) E5(e) G5(e) A5(q.) G5(e)
o2c4 e8 g8 a4. g8
% bar 4: F5(q) E5(e) D5(e) C5(q) A4(q) — F→E→D クロマチック
o2f4 e8 d8 c4 o1a4
% bar 5: A4→F5 8分音符ウォーク
o1a8 o2c8 e8 f8 e8 d8 e8 f8
% bar 6: G5(q) E5(e) C5(e) A4(q) E5(q)
o2g4 e8 c8 o1a4 o2e4
% bar 7: A5(q) G5(e) F5(e) E5(q.) D5(e) — クライマックス
o2a4 g8 f8 e4. d8
% bar 8: C5(q) B4(q) A4(h) — Aマイナー解決
o2c4 o1b4 a2
]

% ── Part B × 2  (8bars × 2 = 16bars) ─────────────────────────────────
[2
% bar 1: A5→D5 半音階下降ラン
o2a8 g+8 g8 f+8 f8 e8 d+8 d8
% bar 2: C5→C6 半音階上昇ラン
o2c8 d8 e8 f8 g8 a8 o1b8 o2c8
% bar 3: E5 リズム強調 (シンコペーション)
o2e4 e8 e8 f4 e8 d8
% bar 4: C5 リズム強調
o2c4 c8 c8 d4 e8 f8
% bar 5: E5→B5 スケール上昇 + 折り返し
o2e8 f8 g8 a8 b8 a8 g8 f8
% bar 6: E5(q.) D5(e) C5(e) B4(e) A4(q) — 段階下降
o2e4. d8 c8 o1b8 a4
% bar 7: A5/A4 オクターブ交互 — テンション
o2a4 o1a4 o2a4 o1a4
% bar 8: A5→A4 半音階下降ラン
o2a8 g8 f8 e8 d8 c8 o1b8 a8
]

% ── Reprise × 2  (8bars × 2 = 16bars) ────────────────────────────────
[2
o1a4 o2c8 e8 a4 g8 f8
o2e4. d8 c4 o1b4
o2c4 e8 g8 a4. g8
o2f4 e8 d8 c4 o1a4
o1a8 o2c8 e8 f8 e8 d8 e8 f8
o2g4 e8 c8 o1a4 o2e4
o2a4 g8 f8 e4. d8
o2c4 o1b4 a2
]

t255


@ t39

% ══════════════════════════════════════════════════════════════════════
% CH2: BASS — A マイナー ルートモーション
% ══════════════════════════════════════════════════════════════════════

% ── Part A bass  (4bars × 4 = 16bars) ────────────────────────────────
[4
% bar 1: Am ルート + 5度 E4
o1 a8 a8 a8 a8 e8 e8 e8 e8
% bar 2: A4-G4 パルス (緊張感)
o1 a8 g8 a8 g8 a8 g8 a8 g8
% bar 3: F4 → C4 (Fmaj ベース)
o1 f8 f8 f8 f8 c8 c8 c8 c8
% bar 4: E4 上行ドライブ → A4
o1 e8 e8 e8 e8 e8 f8 g8 a8
]

% ── Part B bass  (4bars × 4 = 16bars) ────────────────────────────────
[4
% bar 1: Am アルペジオ上昇 A4-C4-E4-G4
o1 a8 a8 c8 c8 e8 e8 g8 g8
% bar 2: Am アルペジオ下降 G4-E4-C4-A4
o1 g8 g8 e8 e8 c8 c8 a8 a8
% bar 3: Fmaj ベース F4-A4-C4
o1 f8 f8 a8 a8 c8 c8 a8 a8
% bar 4: Em ベース E4-G4-B4
o1 e8 e8 g8 g8 b8 b8 g8 g8
]

% ── Reprise bass  (4bars × 4 = 16bars) ───────────────────────────────
[4
o1 a8 a8 a8 a8 e8 e8 e8 e8
o1 a8 g8 a8 g8 a8 g8 a8 g8
o1 f8 f8 f8 f8 c8 c8 c8 c8
o1 e8 e8 e8 e8 e8 f8 g8 a8
]

t255


@ t255

% CH3: 効果音用 (予約)


@ t39

% ══════════════════════════════════════════════════════════════════════
% CH4: DRUMS — NES 風 16分音符パターン (48bars)
%
% 1bar パターン (16分音符 × 16):
%   kick(1) hat hat hat  snare(2) hat hat hat
%   kick(3) hat hat hat  snare(4) hat hat hat
% ══════════════════════════════════════════════════════════════════════

[48 d16 e16 e16 e16 d+16 e16 e16 e16 d16 e16 e16 e16 d+16 e16 e16 e16]

t255
