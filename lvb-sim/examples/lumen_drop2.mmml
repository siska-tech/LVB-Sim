% ─────────────────────────────────────────────────────────────────────
% lumen_drop.mmml  —  Lumen Drop
%                      Korobeiniki (テトリスA面テーマ) × テクノアレンジ
%
% t45 ≈ 140 BPM  |  4/4  |  36 bars  |  約62秒
%
%   CH1 : リードメロディ (Korobeiniki メインテーマ)
%   CH2 : ベースライン  (E マイナー ルートモーション)
%   CH3 : ハーモニー    (3度/5度 アルペジオ)
%   CH4 : ドラム        (4-on-the-floor テクノパターン)
%
% mmml オクターブ対応:
%   o1 → 第4オクターブ (C4≈262Hz, E4≈330Hz, A4≈440Hz, B4≈494Hz)
%   o2 → 第5オクターブ (C5≈523Hz, D5≈587Hz, E5≈659Hz, A5≈880Hz)
%
% CH4 サンプルマップ:
%   d  → kick  (sample 3: ピッチ急降下)
%   d+ → snare (sample 4: 擬似ランダムノイズ)
%   e  → hi-hat (sample 5: 高域バースト)
%
% 構成:
%   Part A × 2  : 7bars × 2 = 14bars  (Korobeiniki A部 2周)
%   Part B × 2  : 4bars × 2 =  8bars  (Korobeiniki B部)
%   Reprise × 2 : 7bars × 2 = 14bars  (A部リプライズ)
%   合計 36bars
% ─────────────────────────────────────────────────────────────────────


@ t45

% ══════════════════════════════════════════════════════════════════════
% CH1: LEAD — Korobeiniki メロディ
% ══════════════════════════════════════════════════════════════════════

% ── Part A × 2  (7bars × 2 = 14bars) ─────────────────────────────────
[2
% bar 1 : E5 B4 C5 D5 C5 B4 A4 A4
o2e8 o1b8 o2c8 d8 c8 o1b8 a8 a8
% bar 2 : C5 E5 D5 C5 B4(q) C5 D5
o2c8 e8 d8 c8 o1b4 o2c8 d8
% bar 3 : E5.(q.) C5(e) A4(q) A4(e) rest
o2e4. c8 o1a4 a8 r8
% bar 4 : E5 B4 C5 D5 C5 B4 A4(q)
o2e8 o1b8 o2c8 d8 c8 o1b8 a4
% bar 5 : C5 E5 D5 C5 B4(q) rest D5
o2c8 e8 d8 c8 o1b4 r8 o2d8
% bar 6 : E5.(q.) C5(e) A4(q) A4(q)
o2e4. c8 o1a4 a4
% bar 7 : 全休符 (フレーズ区切り)
r1
]

% ── Part B × 2  (4bars × 2 = 8bars) ──────────────────────────────────
[2
% bar 1 : D5(q.) F#5(e) A5(q) G5(e) F#5(e)  [Dメジャーアルペジオ上昇]
o2d4. f+8 a4 g8 f+8
% bar 2 : E5(q) C5(e) E5(e) D5(e) C5(e) B4(e) B4(e)
o2e4 c8 e8 d8 c8 o1b8 b8
% bar 3 : B4(e) C5(e) D5(q) E5(q) C5(q)
o1b8 o2c8 d4 e4 c4
% bar 4 : A4(q) A4(h) rest(q)  [A マイナー解決]
o1a4 a2 r4
]

% ── Reprise × 2  (7bars × 2 = 14bars) ────────────────────────────────
[2
o2e8 o1b8 o2c8 d8 c8 o1b8 a8 a8
o2c8 e8 d8 c8 o1b4 o2c8 d8
o2e4. c8 o1a4 a8 r8
o2e8 o1b8 o2c8 d8 c8 o1b8 a4
o2c8 e8 d8 c8 o1b4 r8 o2d8
o2e4. c8 o1a4 a4
r1
]

t255


@ t45

% ══════════════════════════════════════════════════════════════════════
% CH2: BASS — E マイナー ルートモーション
% ══════════════════════════════════════════════════════════════════════

% ── Part A bass  (2bars × 7 = 14bars) ────────────────────────────────
[7
% bar 1: E4 ルート + 5度 (B4) 往復
o1 e8 e8 e8 e8 b8 b8 b8 b8
% bar 2: A4 → G4 → F#4 → E4 クロマチック下降
o1 a8 a8 g8 g8 f+8 f+8 e8 e8
]

% ── Part B bass  (2bars × 4 = 8bars) ─────────────────────────────────
[4
% bar 1: D4 ルート + A4
o1 d8 d8 a8 a8 f+8 f+8 a8 a8
% bar 2: E4 → B4 → G4 → E4 (Eマイナーペンタ)
o1 e8 e8 b8 b8 g8 g8 e8 e8
]

% ── Reprise bass  (2bars × 7 = 14bars) ───────────────────────────────
[7
o1 e8 e8 e8 e8 b8 b8 b8 b8
o1 a8 a8 g8 g8 f+8 f+8 e8 e8
]

t255

@ t45

% ══════════════════════════════════════════════════════════════════════
% CH3: HARMONY — 3度/5度 アルペジオ (CHA をリードと共有)
% ══════════════════════════════════════════════════════════════════════

% ── Part A harmony  (2bars × 7 = 14bars) ─────────────────────────────
[7
% bar 1: Eマイナーコード (G4 B4) アルペジオ
o1 g8 b8 g8 b8 g8 b8 g8 b8
% bar 2: Eマイナー → Dメジャー コードトーン
o1 e8 g8 e8 g8 d8 f+8 d8 f+8
]

% ── Part B harmony  (2bars × 4 = 8bars) ──────────────────────────────
[4
% bar 1: Dメジャーコード (F#4 A4) アルペジオ
o1 f+8 a8 f+8 a8 d8 f+8 d8 f+8
% bar 2: Eマイナー (E4 G4 B4) アルペジオ
o1 e8 g8 b8 g8 e8 g8 b8 e8
]

% ── Reprise harmony  (2bars × 7 = 14bars) ────────────────────────────
[7
o1 g8 b8 g8 b8 g8 b8 g8 b8
o1 e8 g8 e8 g8 d8 f+8 d8 f+8
]

t255

@ t45

% ══════════════════════════════════════════════════════════════════════
% CH4: DRUMS — テクノ 4-on-the-floor (36bars)
%
% 1bar パターン: kick(1拍) hat(&1) snare(2拍) hat(&2)
%                kick(3拍) hat(&3) snare(4拍) hat(&4)
% ══════════════════════════════════════════════════════════════════════

[36 d8 e8 d+8 e8 d8 e8 d+8 e8]

t255
