% ─────────────────────────────────────────────────────────────
% drum_test.mmml  —  パーカッションサンプル単体テスト
%
% CH4 サンプルマップ (μMML note nibble → sample_id):
%   c   → sample 1 : bwoop  (~21ms, 下降トーン 1200→150 Hz)
%   c+  → sample 2 : beep   (~15ms, 800 Hz 矩形波)
%   d   → sample 3 : kick   (~33ms, ピッチ急降下 4800→150 Hz)
%   d+  → sample 4 : snare  (~30ms, 擬似ランダムノイズ)
%   e   → sample 5 : hi-hat (~7ms,  高域ノイズバースト)
%
% CH1-3: 無音 (t255 で即終了)
% CH4 : ドラムのみ。各セクション間に r1 (全休符) を挟む。
%
% テンポ: t52 ≈ 121 BPM
%   四分音符 ≈ 0.50s
%   全休符   ≈ 2.0s  (セクション区切り)
% ─────────────────────────────────────────────────────────────

@ t255
@ t255
@ t255
@ t52

% ── Section 1: kick ──────────────────────────────────────────
% 4分音符 × 4 hit、各 hit 後に 4分休符。計 2 小節。
[4 d4 r4]
r1

% ── Section 2: snare ─────────────────────────────────────────
[4 d+4 r4]
r1

% ── Section 3: hi-hat ────────────────────────────────────────
% 8分音符 × 8 hit。ハイハットの短さを確認。
[8 e8 r8]
r1

% ── Section 4: bwoop ─────────────────────────────────────────
[4 c4 r4]
r1

% ── Section 5: beep ──────────────────────────────────────────
[4 c+4 r4]
r1

% ── Section 6: 全種連打 ───────────────────────────────────────
% kick → snare → hihat → bwoop → beep を順番に 2 回ずつ。
d4 d4 r2 d+4 d+4 r2 e4 e4 r2 c4 c4 r2 c+4 c+4 r2
r1

% ── Section 7: 典型的なドラムパターン (4 小節) ───────────────
% beat: 1    &    2    &    3    &    4    &
%        kick hat  sn   hat  kick hat  sn   hat
[4 d8 e8 d+8 e8 d8 e8 d+8 e8]

t255
